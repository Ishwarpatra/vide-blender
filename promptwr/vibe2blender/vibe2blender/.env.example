# ──────────────────────────────────────────────────────────────────────
# TEMPLATE — Copy this file to .env.server and fill in real values.
# NEVER commit .env.server — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────

# ─── Database Configuration ───────────────────────────────────────────
# PostgreSQL connection string injected at Docker runtime (never hardcode).
DATABASE_URL="postgresql://postgres:changeme@db:5432/vibe2blender"

# ─── Wasp Auth ────────────────────────────────────────────────────────
WASP_AUTH_TOKEN_SECRET=replace_with_a_long_random_secret_string

# ─── Cloud AI (Gemini) ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gemini Context Caching ───────────────────────────────────────────
# Optionally pre-set a known cache name (e.g. from a previous deployment)
# so the manager skips the initial cache-creation API call on cold start.
# Leave blank to let geminiCacheManager.ts auto-create and manage the cache.
GEMINI_CACHE_NAME=

# ─── Local AI (Ollama/Qwen) ─────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5
