datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  password       String
  createdAt      DateTime        @default(now())
  blenderScripts BlenderScript[]
}

model BlenderScript {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  originalPrompt String
  refinedPrompt  String
  generatedCode  String
  // Absolute path on the host to the sandbox-generated .glb preview file.
  // Null until the blender-executor container completes successfully.
  glbPath        String?
  createdAt      DateTime @default(now())
}
